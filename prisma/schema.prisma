generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user") // "user" | "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@map("users")
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  items     Json     // [{ productId, name, price, quantity, image }]
  total     Float
  shipping  Json     // { name, email, phone, address, city, zipCode }
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())

  @@map("categories")
}

model Product {
  id                 String   @id @default(uuid())
  name               String
  price              Float
  image              String
  images             String[] @default([])
  description        String?
  fullDescription    String?
  originalPrice      Float?
  combos             Json?
  featured           Boolean  @default(false)
  category           String   @default("geral")
  stock              Int      @default(0)
  lowStockThreshold  Int?     // alerta quando stock <= este valor
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("products")
}

model ManualSale {
  id        String   @id @default(uuid())
  items     Json     // [{ id, name, price, quantity }]
  total     Float
  createdAt DateTime @default(now())

  @@map("manual_sales")
}
